doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title= title
        //- Esta línea es fundamental para que cargue los colores y diseños
        link(rel="stylesheet", href="/css/style.css") 
    body
        header
            h1 La Espiga de Oro S.R.L.
            h2= title

        main
            section.actions
                a.btn-secondary(href="/pedidos") ⬅ Volver al listado
            hr

            //- Formulario que hace el POST al controlador
            form(action="/pedidos/nuevo", method="POST")
                
                //- Menú desplegable iterando los clientes enviados por el controlador
                div
                    label(for="sucursal") Seleccione la Sucursal (Cliente):
                    select(name="sucursal" id="sucursal" required)
                        option(value="") -- Seleccione un cliente --
                        if clientes && clientes.length > 0
                            each cliente in clientes
                                option(value=cliente.id) #{cliente.nombre}
                        else
                            option(value="") Error: No hay clientes registrados
                
                //- Casillas de verificación iterando los productos
                div
                    label Productos solicitados:
                    if productos && productos.length > 0
                        each producto in productos
                            div(style="margin-bottom: 8px; padding: 5px; background: #f9f9f9; border-radius: 4px;")
                                input(type="checkbox" name="productos" value=producto.id id=`prod-${producto.id}`)
                                label(for=`prod-${producto.id}` style="display:inline; margin-left: 5px; font-weight: normal;") #{producto.nombre} - $#{producto.precio}
                    else
                        p Error: No hay productos registrados

                div(style="text-align: center; margin-top: 20px;")
                    button.btn-primary(type="submit" style="width: 100%; font-size: 1.1rem;") ✔️ Guardar Pedido